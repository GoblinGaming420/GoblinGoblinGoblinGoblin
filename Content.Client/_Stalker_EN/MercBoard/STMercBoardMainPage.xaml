<BoxContainer xmlns="https://spacestation14.io"
              xmlns:merc="clr-namespace:Content.Client._Stalker_EN.MercBoard"
              xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
              Orientation="Vertical"
              HorizontalExpand="True"
              VerticalExpand="True"
              Margin="4">

    <!-- Header -->
    <Label Name="HeaderLabel" StyleClasses="LabelHeading" Text="{Loc 'st-merc-board-header-title'}" Margin="0 0 0 4"/>

    <customControls:HSeparator Margin="0 2 0 2"/>

    <!-- Tab buttons -->
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2 0 4">
        <Button Name="ServicesTabButton" HorizontalExpand="True" Margin="0 0 2 0"/>
        <Button Name="JobsTabButton" HorizontalExpand="True" Margin="2 0 0 0"/>
    </BoxContainer>

    <!-- Search bar -->
    <LineEdit Name="SearchBar" HorizontalExpand="True" PlaceHolder="{Loc 'st-merc-board-search-placeholder'}" Margin="0 0 0 4"/>

    <!-- Info label (count or hint text) -->
    <Label Name="InfoLabel" StyleClasses="LabelSubText" Margin="0 0 0 4"/>

    <!-- Cards area (WrapContainer added in code-behind inside ScrollContainer) -->
    <ScrollContainer Name="CardScroll" VerticalExpand="True" HScrollEnabled="False" MinSize="0 200">
    </ScrollContainer>

    <customControls:HSeparator Margin="0 4 0 4"/>

    <!-- Post button (only visible when allowed) -->
    <Button Name="PostButton" HorizontalExpand="True" Visible="False"/>

</BoxContainer>
